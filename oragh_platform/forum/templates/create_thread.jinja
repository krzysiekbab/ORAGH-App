{% extends "base.jinja" %}

{% block title %}Nowy wątek - {{ category.name }}{% endblock %}
{% block page_title %}Nowy wątek{% endblock %}

{% block content %}

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb mb-2">
        <li class="breadcrumb-item"><a href="{% url 'forum:index' %}">Forum</a></li>
        <li class="breadcrumb-item"><a href="{{ category.get_absolute_url }}">{{ category.name }}</a></li>
        <li class="breadcrumb-item active" aria-current="page">Nowy wątek</li>
      </ol>
    </nav>
    <h4 class="mb-0">Utwórz nowy wątek w kategorii: {{ category.name }}</h4>
  </div>
  <div>
    <a href="{{ category.get_absolute_url }}" class="btn btn-outline-secondary">
      ← Anuluj
    </a>
  </div>
</div>

<form method="post" class="mb-4">
  {% csrf_token %}
  
  <div class="card">
    <div class="card-header">
      <h5 class="mb-0">📝 Szczegóły wątku</h5>
    </div>
    <div class="card-body">
      <div class="row g-3">
        <div class="col-12">
          <label for="title" class="form-label">Tytuł wątku</label>
          <input type="text" class="form-control" id="title" name="title" 
                 value="{{ title|default:'' }}" 
                 placeholder="Wprowadź tytuł wątku..." 
                 required>
          <div class="form-text">Wybierz opisowy tytuł, który jasno określa temat wątku</div>
        </div>
        
        <div class="col-12">
          <label for="content" class="form-label">Treść pierwszego postu</label>
          <textarea name="content" id="content" class="form-control" rows="8" 
                    placeholder="Napisz treść swojego postu..." 
                    required>{{ content|default:'' }}</textarea>
          <div class="form-text">Przedstaw swój temat w jasny i szczegółowy sposób</div>
        </div>
      </div>
    </div>
  </div>

  <div class="d-flex justify-content-between mt-4">
    <a href="{{ category.get_absolute_url }}" class="btn btn-secondary">
      ❌ Anuluj
    </a>
    <button type="submit" class="btn btn-primary">
      ✅ Utwórz wątek
    </button>
  </div>
</form>

<div class="card">
  <div class="card-header">
    <h6 class="mb-0">💡 Wskazówki</h6>
  </div>
  <div class="card-body">
    <ul class="mb-0 small text-muted">
      <li>Wybierz opisowy tytuł, który jasno określa temat dyskusji</li>
      <li>Przedstaw swój temat w sposób jasny i zrozumiały</li>
      <li>Sprawdź, czy podobny wątek już nie istnieje</li>
      <li>Bądź uprzejmy i szanuj innych użytkowników</li>
      {% if category.access_level == 'board' %}
        <li class="text-warning"><strong>To jest kategoria tylko dla zarządu</strong></li>
      {% endif %}
    </ul>
  </div>
</div>

<style>
/* Enhanced mobile responsiveness */
@media (max-width: 768px) {
  .d-flex.justify-content-between {
    flex-direction: column;
    gap: 1rem;
    align-items: stretch;
  }
  
  .d-flex.justify-content-between > div {
    text-align: center;
  }
  
  .breadcrumb {
    justify-content: center;
  }
  
  .d-flex.justify-content-between.mt-4 .btn {
    width: 100%;
    margin-bottom: 0.5rem;
  }
  
  .d-flex.justify-content-between.mt-4 {
    flex-direction: column;
  }
}

@media (max-width: 576px) {
  .card {
    border-radius: 0.25rem;
    margin: 0 -0.5rem 1rem -0.5rem;
  }
  
  .card-body {
    padding: 1rem;
  }
  
  .card-header {
    padding: 0.75rem 1rem;
  }
  
  .form-label {
    font-weight: 600;
    margin-bottom: 0.5rem;
  }
  
  .btn {
    font-size: 0.9rem;
    padding: 0.75rem 1rem;
  }
  
  h4 {
    font-size: 1.25rem;
  }
  
  h5 {
    font-size: 1.125rem;
  }
  
  h6 {
    font-size: 1rem;
  }
}

/* Form styling improvements */
.form-control:focus {
  border-color: #86b7fe;
  box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
}

.form-text {
  color: #6c757d;
  line-height: 1.4;
  font-size: 0.875rem;
}

textarea.form-control {
  resize: vertical;
  min-height: 150px;
}

.form-control, .form-select {
  border: 1px solid #ced4da;
  border-radius: 0.375rem;
  padding: 0.375rem 0.75rem;
}

.form-label {
  margin-bottom: 0.5rem;
  font-weight: 500;
}

/* Card styling */
.card-header {
  background-color: #f8f9fa;
  border-bottom: 1px solid #dee2e6;
}

.card-header h5,
.card-header h6 {
  color: #495057;
  margin-bottom: 0;
}

/* Tips card styling */
.card:last-child .card-header {
  background-color: #e3f2fd;
}

.card:last-child {
  border: 1px solid #bbdefb;
}
</style>
{% endblock %}
