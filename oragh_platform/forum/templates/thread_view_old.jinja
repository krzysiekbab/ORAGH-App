{% extends "base.jinja" %}

{% block title %}{{ thread.title }} - Forum{% endblock %}
{% block page_title %}{{ thread.title }}{% endblock %}

{% block content %}

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb mb-2">
        <li class="breadcrumb-item"><a href="{% url 'forum:index' %}">Forum</a></li>
        <li class="breadcrumb-item"><a href="{{ thread.category.get_absolute_url }}">{{ thread.category.name }}</a></li>
        <li class="breadcrumb-item active" aria-current="page">{{ thread.title }}</li>
      </ol>
    </nav>
    <h4 class="mb-0">
      {{ thread.title }}
      {% if thread.is_pinned %}
        <span class="badge bg-warning text-dark ms-2">Przypięty</span>
      {% endif %}
      {% if thread.is_locked %}
        <span class="badge bg-danger ms-2">Zablokowany</span>
      {% endif %}
    </h4>
  </div>
  <div>
    <a href="{{ thread.category.get_absolute_url }}" class="btn btn-outline-secondary">
      ← Powrót do kategorii
    </a>
  </div>
</div>

<!-- Posts -->
<div class="row g-4">
  {% for post in posts %}
    <div class="col-12" id="post-{{ post.id }}">
      <div class="card">
        <div class="card-header bg-light d-flex justify-content-between align-items-center">
          <div class="d-flex align-items-center">
            {% if post.author.musicianprofile.photo %}
              <img src="{{ post.author.musicianprofile.photo.url }}" 
                   class="rounded-circle me-3" 
                   alt="Zdjęcie profilowe" 
                   style="width: 32px; height: 32px; object-fit: cover;">
            {% else %}
              <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center me-3" 
                   style="width: 32px; height: 32px;">
                <i class="fas fa-user text-white" style="font-size: 0.8rem;"></i>
              </div>
            {% endif %}
            <div>
              <h6 class="mb-0">{{ post.author.first_name }} {{ post.author.last_name }}</h6>
              <small class="text-muted">
                {{ post.created_at|date:"d.m.Y H:i" }}
                {% if post.is_edited %}
                  • <em>edytowany {{ post.updated_at|date:"d.m.Y H:i" }}</em>
                {% endif %}
              </small>
            </div>
          </div>
          <div class="d-flex gap-2">
            {% if user == post.author or user.is_staff %}
              <a href="{% url 'forum:edit_post' post.id %}" class="btn btn-sm btn-outline-primary" title="Edytuj post">
                ✏️
              </a>
              <a href="{% url 'forum:delete_post' post.id %}" class="btn btn-sm btn-outline-danger" title="Usuń post">
                🗑️
              </a>
            {% endif %}
          </div>
        </div>
        <div class="card-body">
          <div class="post-content">
            {{ post.content|linebreaks }}
          </div>
        </div>
      </div>
    </div>
  {% endfor %}
</div>

<!-- Pagination -->
{% if posts.has_other_pages %}
  <nav aria-label="Paginacja postów" class="mt-4">
    <ul class="pagination justify-content-center">
      {% if posts.has_previous %}
        <li class="page-item">
          <a class="page-link" href="?page=1">Pierwsza</a>
        </li>
        <li class="page-item">
          <a class="page-link" href="?page={{ posts.previous_page_number }}">Poprzednia</a>
        </li>
      {% endif %}
      
      <li class="page-item active">
        <span class="page-link">
          Strona {{ posts.number }} z {{ posts.paginator.num_pages }}
        </span>
      </li>
      
      {% if posts.has_next %}
        <li class="page-item">
          <a class="page-link" href="?page={{ posts.next_page_number }}">Następna</a>
        </li>
        <li class="page-item">
          <a class="page-link" href="?page={{ posts.paginator.num_pages }}">Ostatnia</a>
        </li>
      {% endif %}
    </ul>
  </nav>
{% endif %}

<!-- Reply Form -->
{% if can_reply %}
  <div class="card mt-4">
    <div class="card-header">
      <h5 class="mb-0">💬 Odpowiedz</h5>
    </div>
    <div class="card-body">
      <form method="post" action="{% url 'forum:create_post' thread.id %}">
        {% csrf_token %}
        <div class="mb-3">
          <label for="content" class="form-label">Treść odpowiedzi</label>
          <textarea name="content" id="content" class="form-control" rows="4" 
                    placeholder="Napisz swoją odpowiedź..." required></textarea>
        </div>
        <div class="d-flex justify-content-end">
          <button type="submit" class="btn btn-primary">Dodaj odpowiedź</button>
        </div>
      </form>
    </div>
  </div>
{% elif thread.is_locked %}
  <div class="alert alert-warning mt-4">
    <i class="fas fa-lock"></i> Ten wątek jest zablokowany. Nie można dodawać nowych odpowiedzi.
  </div>
{% endif %}

<style>
/* Post content styling */
.post-content {
  line-height: 1.6;
  word-wrap: break-word;
}

.post-content p:last-child {
  margin-bottom: 0;
}

/* Enhanced mobile responsiveness */
@media (max-width: 768px) {
  .d-flex.justify-content-between {
    flex-direction: column;
    gap: 1rem;
    align-items: stretch;
  }
  
  .d-flex.justify-content-between > div {
    text-align: center;
  }
  
  .breadcrumb {
    justify-content: center;
  }
  
  .card-header .d-flex.justify-content-between {
    flex-direction: column;
    gap: 0.5rem;
    align-items: center;
  }
  
  .card-header .d-flex.align-items-center {
    flex-direction: column;
    text-align: center;
  }
  
  .card-header .me-3 {
    margin-right: 0 !important;
    margin-bottom: 0.5rem;
  }
  
  .d-flex.gap-2 {
    justify-content: center;
  }
}

@media (max-width: 576px) {
  .card-body {
    padding: 1rem;
  }
  
  .card-header {
    padding: 0.75rem 1rem;
  }
  
  .badge {
    font-size: 0.75rem;
  }
  
  .btn-sm {
    font-size: 0.8rem;
    padding: 0.25rem 0.5rem;
  }
  
  h4 {
    font-size: 1.25rem;
  }
  
  h5 {
    font-size: 1.125rem;
  }
  
  h6 {
    font-size: 1rem;
  }
}

/* Smooth scrolling for anchor links */
html {
  scroll-behavior: smooth;
}

/* Post highlight animation */
.card {
  transition: box-shadow 0.3s ease;
}

.card:target {
  box-shadow: 0 0 0 3px rgba(13, 110, 253, 0.25);
  animation: highlight 2s ease-in-out;
}

@keyframes highlight {
  0% { box-shadow: 0 0 0 3px rgba(13, 110, 253, 0.5); }
  100% { box-shadow: 0 0 0 3px rgba(13, 110, 253, 0.25); }
}

/* Form styling */
.form-control:focus {
  border-color: #86b7fe;
  box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
}

textarea.form-control {
  resize: vertical;
  min-height: 100px;
}

/* Alert styling */
.alert-warning {
  border-left: 4px solid #ffc107;
}
</style>
{% endblock %}
