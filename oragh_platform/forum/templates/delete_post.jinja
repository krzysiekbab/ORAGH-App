{% extends "base.jinja" %}

{% block title %}Usuń post - {{ thread.title }}{% endblock %}
{% block page_title %}Usuń post{% endblock %}

{% block content %}

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb mb-2">
        <li class="breadcrumb-item"><a href="{% url 'forum:index' %}">Forum</a></li>
        <li class="breadcrumb-item"><a href="{{ thread.category.get_absolute_url }}">{{ thread.category.name }}</a></li>
        <li class="breadcrumb-item"><a href="{{ thread.get_absolute_url }}">{{ thread.title }}</a></li>
        <li class="breadcrumb-item active" aria-current="page">Usuń post</li>
      </ol>
    </nav>
    <h4 class="mb-0">Usuń post</h4>
  </div>
  <div>
    <a href="{{ thread.get_absolute_url }}" class="btn btn-outline-secondary">
      ← Anuluj
    </a>
  </div>
</div>

<div class="card border-danger">
  <div class="card-header bg-danger text-white">
    <h5 class="mb-0">⚠️ Potwierdzenie usunięcia</h5>
  </div>
  <div class="card-body">
    <div class="alert alert-warning">
      <h6 class="alert-heading">🚨 Uwaga!</h6>
      <p class="mb-0">
        {% if thread.get_posts_count == 1 %}
          To jest jedyny post w tym wątku. Usunięcie go spowoduje <strong>usunięcie całego wątku</strong>.
        {% else %}
          Czy na pewno chcesz usunąć ten post? Ta operacja jest <strong>nieodwracalna</strong>.
        {% endif %}
      </p>
    </div>
    
    <div class="card">
      <div class="card-header">
        <h6 class="mb-0">Post do usunięcia</h6>
      </div>
      <div class="card-body">
        <div class="d-flex align-items-start mb-3">
          {% if post.author.musicianprofile.photo %}
            <img src="{{ post.author.musicianprofile.photo.url }}" 
                 class="rounded-circle me-3" 
                 alt="Zdjęcie profilowe" 
                 style="width: 32px; height: 32px; object-fit: cover;">
          {% else %}
            <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center me-3" 
                 style="width: 32px; height: 32px;">
              <i class="fas fa-user text-white" style="font-size: 0.8rem;"></i>
            </div>
          {% endif %}
          <div>
            <h6 class="mb-0">{{ post.author.first_name }} {{ post.author.last_name }}</h6>
            <small class="text-muted">
              {{ post.created_at|date:"d.m.Y H:i" }}
              {% if post.is_edited %}
                • <em>edytowany {{ post.updated_at|date:"d.m.Y H:i" }}</em>
              {% endif %}
            </small>
          </div>
        </div>
        <div class="post-content">
          {{ post.content|linebreaks|truncatewords:50 }}
          {% if post.content|wordcount > 50 %}
            <em class="text-muted">... (treść skrócona)</em>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</div>

<form method="post" class="mt-4">
  {% csrf_token %}
  <div class="d-flex justify-content-between">
    <a href="{{ thread.get_absolute_url }}" class="btn btn-secondary">
      ← Anuluj
    </a>
    <button type="submit" class="btn btn-danger" onclick="return confirmDelete()">
      🗑️ 
      {% if thread.get_posts_count == 1 %}
        Usuń wątek
      {% else %}
        Usuń post
      {% endif %}
    </button>
  </div>
</form>

<div class="card mt-4">
  <div class="card-header">
    <h6 class="mb-0">ℹ️ Informacje</h6>
  </div>
  <div class="card-body">
    <ul class="mb-0 small text-muted">
      <li>Usunięcie postu jest operacją nieodwracalną</li>
      {% if thread.get_posts_count == 1 %}
        <li>To jest jedyny post w wątku - usunięcie go spowoduje usunięcie całego wątku</li>
        <li>Wątek zniknie z listy wątków w kategorii</li>
      {% else %}
        <li>Pozostałe posty w wątku pozostaną nietknięte</li>
        <li>Numeracja postów może się zmienić</li>
      {% endif %}
      <li>Tylko autor postu lub moderator może go usunąć</li>
    </ul>
  </div>
</div>

<script>
function confirmDelete() {
    {% if thread.get_posts_count == 1 %}
        return confirm('Czy na pewno chcesz usunąć ten wątek?\n\nTa operacja jest nieodwracalna i usunie cały wątek wraz z tym postem.');
    {% else %}
        return confirm('Czy na pewno chcesz usunąć ten post?\n\nTa operacja jest nieodwracalna.');
    {% endif %}
}
</script>

<style>
/* Card border danger styling */
.card-border-danger {
  border-color: #dc3545;
}

/* Enhanced mobile responsiveness */
@media (max-width: 768px) {
  .d-flex.justify-content-between {
    flex-direction: column;
    gap: 1rem;
    align-items: stretch;
  }
  
  .d-flex.justify-content-between > div {
    text-align: center;
  }
  
  .breadcrumb {
    justify-content: center;
  }
  
  .d-flex.justify-content-between .btn {
    width: 100%;
    margin-bottom: 0.5rem;
  }
}

@media (max-width: 576px) {
  .card {
    border-radius: 0.25rem;
    margin: 0 -0.5rem 1rem -0.5rem;
  }
  
  .card-body {
    padding: 1rem;
  }
  
  .card-header {
    padding: 0.75rem 1rem;
  }
  
  .btn {
    font-size: 0.9rem;
    padding: 0.75rem 1rem;
  }
  
  h4 {
    font-size: 1.25rem;
  }
  
  h5 {
    font-size: 1.125rem;
  }
  
  h6 {
    font-size: 1rem;
  }
  
  .d-flex.align-items-start {
    flex-direction: column;
    text-align: center;
  }
  
  .me-3 {
    margin-right: 0 !important;
    margin-bottom: 0.5rem;
  }
}

/* Alert styling */
.alert-warning {
  border-left: 4px solid #ffc107;
}

/* Post content styling */
.post-content {
  line-height: 1.6;
  word-wrap: break-word;
  background-color: #f8f9fa;
  padding: 1rem;
  border-radius: 0.375rem;
  border: 1px solid #dee2e6;
}

.post-content p:last-child {
  margin-bottom: 0;
}

/* Button styling */
.btn-danger {
  background-color: #dc3545;
  border-color: #dc3545;
}

.btn-danger:hover {
  background-color: #c82333;
  border-color: #bd2130;
}
</style>
{% endblock %}
