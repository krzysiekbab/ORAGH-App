{% extends "base.jinja" %}

{% block title %}Edytuj komentarz - {{ thread.title }} - Forum{% endblock %}
{% block page_title %}Edytuj komentarz{% endblock %}

{% block content %}

<div class="row justify-content-center">
  <div class="col-md-8 col-lg-6">
    
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{% url 'forum:index' %}">Forum</a></li>
        <li class="breadcrumb-item"><a href="{{ thread.category.get_absolute_url }}">{{ thread.category.name }}</a></li>
        {% if thread.directory %}
          <li class="breadcrumb-item"><a href="{{ thread.directory.get_absolute_url }}">{{ thread.directory.name }}</a></li>
        {% endif %}
        <li class="breadcrumb-item"><a href="{{ thread.get_absolute_url }}">{{ thread.title }}</a></li>
        <li class="breadcrumb-item active" aria-current="page">Edytuj komentarz</li>
      </ol>
    </nav>

    <div class="card">
      <div class="card-header">
        <h5 class="mb-0">✏️ Edytuj komentarz</h5>
      </div>
      <div class="card-body">
        
        <!-- Display messages if any -->
        {% if messages %}
          {% for message in messages %}
            <div class="alert alert-{{ message.tags }} alert-dismissible fade show" role="alert">
              {{ message }}
              <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Zamknij"></button>
            </div>
          {% endfor %}
        {% endif %}

        <!-- Comment info -->
        <div class="alert alert-info mb-4">
          <h6 class="alert-heading">Edytujesz komentarz w wątku:</h6>
          <p class="mb-1"><strong>{{ thread.title }}</strong></p>
          <small class="text-muted">
            Pierwotnie utworzony: {{ comment.created_at|date:"d.m.Y H:i" }}
          </small>
        </div>

        <form method="post">
          {% csrf_token %}
          
          <div class="mb-4">
            <label for="content" class="form-label">Treść komentarza *</label>
            <textarea class="form-control" 
                      id="content" 
                      name="content" 
                      rows="8"
                      placeholder="Napisz treść swojego komentarza..."
                      required>{{ comment.content }}</textarea>
            <div class="form-text">
              <i class="fas fa-info-circle"></i>
              Po zapisaniu edycji komentarz zostanie oznaczony jako edytowany
            </div>
          </div>
          
          <div class="d-flex justify-content-between">
            <a href="{{ thread.get_absolute_url }}" class="btn btn-outline-secondary">
              ← Anuluj
            </a>
            <button type="submit" class="btn btn-primary">
              ✏️ Zapisz zmiany
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<style>
.card {
  border-radius: 12px;
  box-shadow: 0 4px 16px rgba(0,0,0,0.1);
}

.card-header {
  background: linear-gradient(135deg, #0d6efd 0%, #0b5ed7 100%);
  color: white;
  border-radius: 12px 12px 0 0;
}

.form-control:focus {
  border-color: #0d6efd;
  box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
}

.btn-primary {
  background: linear-gradient(135deg, #0d6efd 0%, #0b5ed7 100%);
  border: none;
}

.btn-primary:hover {
  background: linear-gradient(135deg, #0b5ed7 0%, #0a58ca 100%);
  transform: translateY(-1px);
  box-shadow: 0 2px 8px rgba(0,0,0,0.15);
}

.alert-info {
  border-left: 4px solid #0dcaf0;
  background-color: #e7f3ff;
  border-color: #b6effb;
}

.breadcrumb {
  background: none;
  padding: 0;
}

textarea.form-control {
  resize: vertical;
  min-height: 120px;
}
</style>

{% endblock %}
